# === REQUIRED for deployment ===

# Upstash Redis (create free instance at https://console.upstash.com)
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# === SERVER CONFIG (optional — defaults shown) ===

# HTTP listen port for local Express server. Vercel ignores this.
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# CORS origin allow-list. Comma-separated list, or '*' for any.
CORS_ORIGIN=*

# Pino logger level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# === OPTIONAL DATA SOURCES — graceful degradation if missing ===

# OpenSky Network (register at https://opensky-network.org)
# OAuth2 client credentials — create at OpenSky Dashboard -> API Clients
OPENSKY_CLIENT_ID=your-client-id
OPENSKY_CLIENT_SECRET=your-client-secret

# AISStream.io (register at https://aisstream.io, sign in via GitHub)
# Copy API key from Dashboard
AISSTREAM_API_KEY=your-aisstream-api-key

# ADS-B Exchange via RapidAPI (subscribe at https://rapidapi.com/adsbx/api/adsbexchange-com1)
ADSB_EXCHANGE_API_KEY=your-rapidapi-key

# ACLED (register at https://acleddata.com) — adapter present but inactive
# Use your registration email and password
ACLED_EMAIL=your-email@example.com
ACLED_PASSWORD=your-password

# === EVENT PIPELINE TUNING ===

# Minimum composite confidence (0-1) for a GDELT event to be retained
EVENT_CONFIDENCE_THRESHOLD=0.35

# Minimum independent NumSources for a GDELT row to be considered
EVENT_MIN_SOURCES=2

# Multiplicative confidence penalty (0-1) when ActionGeo coords match a city centroid
EVENT_CENTROID_PENALTY=0.7

# Comma-separated CAMEO base codes to exclude from event ingestion
EVENT_EXCLUDED_CAMEO=180,192

# Confidence boost (0-1) when a Bellingcat article corroborates an event
BELLINGCAT_CORROBORATION_BOOST=0.2

# Minimum relevance score (0-1) for news articles to be kept after filtering
NEWS_RELEVANCE_THRESHOLD=0.7
