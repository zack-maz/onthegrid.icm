#!/usr/bin/env bash
# Git workflow enforcement agent
# - Blocks commits to main/master
# - Validates conventional commit format

set -euo pipefail

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

# --- Rule 1: Never commit to main ---
if [[ "$BRANCH" == "main" || "$BRANCH" == "master" ]]; then
  echo -e "${RED}BLOCKED: Direct commits to '$BRANCH' are not allowed.${NC}"
  echo ""
  echo "Create a feature branch first:"
  echo "  git checkout -b feature/<description>"
  echo ""
  exit 1
fi

# --- Rule 2: Conventional commit format ---
# Pattern: type(scope): description
# Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert
CONVENTIONAL_PATTERN='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\([a-zA-Z0-9._-]+\))?: .+'

# Allow merge commits and revert commits
if [[ "$COMMIT_MSG" =~ ^Merge\  ]] || [[ "$COMMIT_MSG" =~ ^Revert\  ]]; then
  exit 0
fi

if ! echo "$COMMIT_MSG" | grep -qE "$CONVENTIONAL_PATTERN"; then
  echo -e "${RED}BLOCKED: Commit message does not follow conventional format.${NC}"
  echo ""
  echo "Expected: type(scope): description"
  echo "  Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
  echo "  Examples:"
  echo "    feat(04): add flight polling hook"
  echo "    fix(map): correct terrain exaggeration"
  echo "    docs(state): record phase 4 context session"
  echo ""
  echo -e "Your message: ${YELLOW}${COMMIT_MSG}${NC}"
  echo ""
  exit 1
fi
